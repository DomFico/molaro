# Dependencies
node_modules/

# Build / compile output (regenerated by `npm run build`)
dist/
out/
*.tsbuildinfo

# Python bytecode / caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Virtualenvs
.venv/
venv/
env/

# Regenerable fixtures & scale-run artifacts.
# The small canonical cross-language fixtures in contract/fixtures/ ARE
# committed (the test suite needs them); everything below is regenerated by the
# producer / fixture scripts (media/fixtures via tests/make_webview_fixture.py,
# large stress .bin blobs, etc.) and must not be committed.
media/fixtures/
*.stress.bin

# Logs
*.log

# Editor / OS cruft. .vscode/launch.json + tasks.json are shared project config
# (the README's "press F5" flow), so they ARE committed; machine-local settings
# are not.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
.DS_Store
Thumbs.db
*.swp
