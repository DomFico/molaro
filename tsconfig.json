{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vscode"]
  },
  "include": ["contract/**/*.ts", "src/**/*.ts", "webview/**/*.ts", "tests/**/*.ts"]
}
