{
  "name": "viewer",
  "displayName": "Point Viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Time-series 3D point dataset viewer. Increment 1: render frame 0 of a synthetic dataset in a CSP-safe webview.",
  "engines": {
    "vscode": "^1.125.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DomFico/molaro.git"
  },
  "main": "./dist/extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "viewer.open",
        "title": "Point Viewer: Open"
      },
      {
        "command": "viewer.openFile",
        "title": "Open in Point Viewer"
      },
      {
        "command": "viewer.openTerminal",
        "title": "Point Viewer: Open Terminal"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "viewer.openFile",
          "when": "resourceExtname =~ /\\.(pdb|gro|mol2|cif|h5|xtc|trr|dcd|nc|netcdf|binpos|mdcrd|crd|trj|dtr|lammpstrj|xyz|prmtop|parm7|psf|top)$/i",
          "group": "navigation@9"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm run build:extension && npm run build:webview",
    "package": "rm -rf dist && npm run build && npx --yes @vscode/vsce package -o viewer-0.1.0.vsix",
    "build:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.cjs",
    "build:webview": "esbuild webview/main.ts webview/terminal.ts webview/plot.ts --bundle --format=iife --minify --outdir=dist/webview",
    "typecheck": "tsc --noEmit",
    "fixtures": "python3 -m tests.make_fixtures && python3 tests/make_webview_fixture.py",
    "test": "node --test tests/contract.test.ts tests/geometry.test.ts tests/framing.test.ts tests/playback.test.ts tests/producer_protocol.test.ts tests/classification.test.ts tests/picking.test.ts tests/sets.test.ts tests/address.test.ts tests/commands.test.ts tests/recipes.test.ts tests/claude.test.ts tests/plot.test.ts tests/claudelayout.test.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "@types/vscode": "^1.125.0",
    "esbuild": "^0.28.1",
    "three": "^0.185.1",
    "typescript": "^6.0.3"
  }
}
